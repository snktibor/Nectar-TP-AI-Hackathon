# NECTAR TP — backend local config.
# Loaded by pydantic-settings (see app/core/settings.py). Do NOT commit secrets.

# Run the audit pipeline against the mock agent service so no Anthropic
# tokens are spent. Flip to `true` (or remove) once you set an API key below.
NECTAR_USE_REAL_AGENTS=false

# Anthropic API key for the real pipeline. Leave empty while using the mock.
# NECTAR_ANTHROPIC_API_KEY=sk-ant-...
NECTAR_ANTHROPIC_API_KEY=

# Keep ChromaDB anonymized telemetry disabled for confidential local data and
# to avoid noisy PostHog telemetry failures with the pinned dependency set.
NECTAR_CHROMA_ANONYMIZED_TELEMETRY=false

# --- Token budget controls (defaults optimised for low-tier API keys) ---
# Model for the 6 specialist doc agents.
# Haiku (default): ~10x cheaper, much higher TPM — use on free/tier-1 keys.
# Sonnet: better reasoning — use on tier-2+ keys with ≥80k TPM headroom.
# NECTAR_MODEL_DOC_AGENT=claude-haiku-4-5-20251001
# NECTAR_MODEL_DOC_AGENT=claude-sonnet-4-6

# Max LLM turns per agent (default 10). Lower = fewer tokens, less detail.
# NECTAR_MAX_TOOL_ITERATIONS=10

# Number of RAG chunks returned per search_context call (default 3).
# NECTAR_RAG_N_RESULTS=3

# Concurrent agents calling the LLM simultaneously (default 1 = serialized).
# Increase only if your API key has enough TPM for N agents at once.
# NECTAR_AGENT_MAX_CONCURRENCY=1

# Minimum seconds between consecutive LLM API calls — applied GLOBALLY across
# all agents (default 10.0). Haiku Tier-1 = 5 000 OTPM; with ~750 output tokens
# per turn, 10 s spacing keeps us at ~4 500 OTPM (under the 5 000 limit).
# Raise to 12-15 s if 429s persist; set to 0 on tier-2+ keys.
# NECTAR_MIN_CALL_INTERVAL_S=10.0

# Per-agent wall-clock budget (default 600 s). Must accommodate
# max_tool_iterations × min_call_interval_s plus retry overhead.
# NECTAR_AGENT_TIMEOUT_S=600.0

# --- Logging ---
# Absolute path of the structured log file. Truncated on every server start;
# auto-flushed after every record so Ctrl+C leaves a complete file on disk.
# Default: <repo_root>/logs/logs.txt. Set to empty to disable file logging.
# NECTAR_LOG_FILE_PATH=<repo_root>/logs/logs.txt

# Truncate the log file on each startup (default true). Set to false to append
# across runs (useful when correlating multiple uvicorn reloads).
# NECTAR_LOG_FILE_TRUNCATE_ON_START=true

# Root log level. INFO is recommended; DEBUG also captures Anthropic SDK
# wire-level details and very verbose internal traces.
# NECTAR_LOG_LEVEL=INFO

# --- Audit reports ---
# Directory where each completed/failed audit report is auto-dumped as JSON.
# Filename: audit_<YYYY-MM-DD_HH-MM-SS>_<task_id_first8>.json. UTF-8, indented,
# Hungarian text preserved (ensure_ascii=False). Set to empty to disable.
# NECTAR_AUDIT_REPORT_DIR=<repo_root>/logs/audit_reports